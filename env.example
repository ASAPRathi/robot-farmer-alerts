# Robot Farmer Configuration
# Copy these variable names into Railway dashboard and fill in your own values

# Your Polygon.io API Key (get from polygon.io/dashboard)
POLYGON_API_KEY=your_polygon_api_key_here

# Your Slack Webhook URL (get from slack.com/apps → Incoming Webhooks)
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Your watchlist (comma-separated, no spaces after commas)
TICKERS=AAPL,TSLA,SPY,QQQ,NVDA,MSFT,AMD,GOOG
